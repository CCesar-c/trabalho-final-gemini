# Copie este arquivo para ".env" (na mesma pasta) e preencha com seus
# próprios valores. O arquivo ".env" nunca deve ser commitado.

PORT=3000

# Chave da API do Gemini — obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Conexão com o PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=final_ia_trabalho
DB_PORT=5433
